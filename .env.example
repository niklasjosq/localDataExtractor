# Copy this file to .env and fill in your secrets.
# .env is gitignored; .env.example is committed as a template.
#
# Resolution priority for the LM Studio API token:
#   1. GUI "API Token" field (in-memory only, lost on close)
#   2. Environment variable below (loaded from .env if present)
#   3. [llm].api_token in config.toml

# LM Studio bearer token, required only if your local server has
# "Require API Key" enabled.
LDX_LMSTUDIO_API_TOKEN=
